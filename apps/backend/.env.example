# =========================
# Database Configuration
# =========================
# Modes supported by database.py:
# - sqlite (default)
# - local (PostgreSQL via DB_HOST)
# - supabase (uses SUPABASE_URL as DB host)
# - proxy (Cloud SQL Auth Proxy at 127.0.0.1)
# - cloud_connector (Google Cloud SQL Connector)
DB_MODE=sqlite

# SQLite mode
SQLITE_PATH=./my_project_database.db

# PostgreSQL credentials (used for local/supabase/proxy/cloud_connector)
DB_USER=postgres
DB_PASSWORD=change-this-password
DB_NAME=postgres
DB_PORT=5432

# Local PostgreSQL host (used when DB_MODE=local)
DB_HOST=localhost

# Supabase Postgres host (used when DB_MODE=supabase)
SUPABASE_URL=db.your-project-ref.supabase.co

# Google Cloud SQL (used when DB_MODE=cloud_connector)
INSTANCE_CONNECTION_NAME=your-project:region:instance-name

# =========================
# Security / JWT
# =========================
# Generate with:
# python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =========================
# Environment / Logging
# =========================
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# CORS (for Next.js frontend)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional
# SQL_ECHO=false
# REDIS_URL=redis://localhost:6379/0
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USERNAME=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
