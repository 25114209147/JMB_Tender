# Database
DB_MODE=sqlite
DATABASE_URL=sqlite:///./app.db

# For PostgreSQL (local, Supabase, Cloud SQL)
DB_USER=postgres
DB_PASSWORD=your-strong-password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres

# For Supabase 
SUPABASE_URL=db.your-supabase-project-ref.supabase.co

# Google Cloud SQL (if using proxy or connector)
INSTANCE_CONNECTION_NAME=your-project:region:instance-name

# Security / JWT: Generate strong key: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-very-long-random-secret-key-here-change-this

# JWT algorithm (HS256 is fine for most cases)
ALGORITHM=HS256

# How long access tokens live (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Environment & Debugging
ENV=development          # development | staging | production
DEBUG=true               # true in dev, false in prod
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR | CRITICAL

# CORS (for Next.js frontend) 
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === Optional later ===
# REDIS_URL=redis://localhost:6379/0
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USERNAME=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password